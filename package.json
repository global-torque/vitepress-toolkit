{
  "name": "@global-torque/vitepress-toolkit",
  "private": false,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "prepare": "pnpm run build",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@global-torque/content-toolkit": "github:global-torque/content-toolkit#master",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "vitepress": "^1.6.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4",
    "vitest": "4.1.7",
    "vue": "^3.5.39"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/global-torque/vitepress-toolkit.git"
  },
  "homepage": "https://github.com/global-torque/vitepress-toolkit#readme",
  "bugs": {
    "url": "https://github.com/global-torque/vitepress-toolkit/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "import": "./dist/content.js"
    },
    "./drafts": {
      "types": "./dist/drafts.d.ts",
      "import": "./dist/drafts.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    },
    "./head": {
      "types": "./dist/head.d.ts",
      "import": "./dist/head.js"
    },
    "./seo": {
      "types": "./dist/seo.d.ts",
      "import": "./dist/seo.js"
    },
    "./sitemap": {
      "types": "./dist/sitemap.d.ts",
      "import": "./dist/sitemap.js"
    }
  }
}
